# This .gitignore file should be placed at the root of your Unity project.
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/[Bb]ird/[Ll]ibrary/
/[Bb]ird/[Tt]emp/
/[Bb]ird/[Oo]bj/
/[Bb]ird/[Bb]uild/
/[Bb]ird/[Bb]uilds/
/[Bb]ird/[Ll]ogs/
/[Bb]ird/[Uu]serSettings/

# MemoryCaptures can get very large.
/[Bb]ird/[Mm]emoryCaptures/

# Asset store packages can be very large and should generally be managed by Unity Editor.
/[Bb]ird/[Aa]ssets/AssetStoreTools*

# Autogenerated VS/MD/Consulo solution and project files
/[Bb]ird/*.csproj
/[Bb]ird/*.unityproj
/[Bb]ird/*.sln
/[Bb]ird/*.suo
/[Bb]ird/*.tmp
/[Bb]ird/*.user
/[Bb]ird/*.userprefs
/[Bb]ird/*.pidb
/[Bb]ird/*.booproj
/[Bb]ird/*.svd
/[Bb]ird/*.pdb
/[Bb]ird/*.mdb
/[Bb]ird/*.opendb
/[Bb]ird/*.VC.db

# Unity3D generated meta files
/[Bb]ird/*.pidb.meta
/[Bb]ird/*.pdb.meta
/[Bb]ird/*.mdb.meta

# Unity3D generated file on crash reports
/[Bb]ird/sysinfo.txt

# Builds
/[Bb]ird/*.apk
/[Bb]ird/*.unitypackage

# Apple
.DS_Store

# Crashlytics
/[Bb]ird/crashlytics-build.properties

# Visual Studio cache directory
/[Bb]ird/.vs/
